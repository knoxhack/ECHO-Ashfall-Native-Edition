    "showcaseFlow": [
        "start at the armored drop pod",
        "open Terminal and read the Ashfall field dashboard",
        "read the Ashfall Showcase Flow Index entry",
        "scan drop-pod wreckage with Lens",
        "pin the first HoloMap field objective",
        "accept the Ashfall Showcase Opening MissionCore mission",
        "respond to the first WeatherCore toxic-front warning",
        "recover a small RelicTech field note",
        "repair the pod PowerGrid spine",
        "install a basic Armory upgrade",
        "follow the first faction/story signal",
        "defer Nexus, Orbital, Stationfall, and Blackbox hooks until the player is supplied"
    ],
    "showcaseIntegrations": {
        "terminal": "Field dashboard summarizes the current next step and links to Index, mission, and marker ids.",
        "index": "Showcase Flow, Profile Isolation, Relic Field Note, and Power Repair entries stay in the Ashfall namespace.",
        "missioncore": "Ashfall Showcase Opening chains the first ECHO systems without adding a new content wave.",
        "holomap": "Showcase Flow layer exposes opening route markers only for the Ashfall official profile.",
        "lens": "Opening scan rows unlock Index and MissionCore context for wreckage, relic, and power repair beats.",
        "weathercore": "Toxic Front warning teaches retreat and shelter without becoming a punishment spike.",
        "soundcore": "Subtle optional cue profile supports Terminal, Lens, relic, and repair feedback.",
        "worldcore": "Showcase Corridor groups the opening route as profile-scoped field intel.",
        "relictech": "First relic field note demonstrates discovery cross-links before Nexus escalation.",
        "powergrid": "Drop-pod grid repair uses the 1.0.0 tech wave as a small survival repair step.",
        "armory": "First Field Upgrade introduces gear readiness before faction pressure rises.",
        "logisticsConvoy": "Depot and convoy hooks remain optional later-route bridges.",
        "stationNexusBlackbox": "Story links are signposted as later hooks, not front-loaded requirements.",
        "themeCore": "Ashfall Cyberglass tokens use orange warning, cyan focus, and dark panel surfaces."
    },
